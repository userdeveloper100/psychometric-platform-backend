generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Institute {
  id        String   @id @default(uuid())
  name      String
  email     String
  users     User[]
  students  Student[]
  tests     PsychometricTest[]
  createdAt DateTime @default(now())
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  role        Role
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  createdAt   DateTime  @default(now())
}

model PsychometricTest {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      TestStatus @default(DRAFT)
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  dimensions  Dimension[]
  invites     TestInvite[]
  createdAt   DateTime @default(now())
}

model Dimension {
  id       String @id @default(uuid())
  name     String
  testId   String
  test     PsychometricTest @relation(fields: [testId], references: [id])
  questions Question[]
}

model Question {
  id          String @id @default(uuid())
  text        String
  dimensionId String
  dimension   Dimension @relation(fields: [dimensionId], references: [id])
  scaleMin    Int
  scaleMax    Int
  responses   Response[]
}

model Student {
  id          String @id @default(uuid())
  name        String
  email       String
  instituteId String
  institute   Institute @relation(fields: [instituteId], references: [id])
  invites     TestInvite[]
}

model TestInvite {
  id        String @id @default(uuid())
  testId    String
  studentId String
  token     String @unique
  status    InviteStatus @default(PENDING)

  test      PsychometricTest @relation(fields: [testId], references: [id])
  student   Student @relation(fields: [studentId], references: [id])
}

model Response {
  id         String @id @default(uuid())
  questionId String
  studentId  String
  answer     Int
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id])
}

enum Role {
  ADMIN
  STUDENT
}

enum TestStatus {
  DRAFT
  PUBLISHED
}

enum InviteStatus {
  PENDING
  COMPLETED
}